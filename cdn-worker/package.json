{
  "name": "cdn-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prebuild": "node build.mjs",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "node build.mjs && wrangler deploy",
    "dev": "node build.mjs && wrangler dev",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "wrangler": "^3.80.0",
    "@cloudflare/workers-types": "^4.20241011.0",
    "typescript": "^5.6.0"
  }
}
